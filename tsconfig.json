{
  "compilerOptions": {
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./.vitepress/*"]
    },
    "allowJs": true,
    "esModuleInterop": true,
    "noEmit": true,
    "lib": ["dom", "esnext"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "include": [".vitepress/**/*"]
}
